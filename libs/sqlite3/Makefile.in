STATICLIB = libsqlite3.a
EXTRAINCL = $(SQLITE3_PE_CFLAGS)
EXTRADEFS = -DSQLITE_ENABLE_RTREE=1 -DSQLITE_ENABLE_FTS4=1 -DSQLITE_ENABLE_COLUMN_METADATA=1 -DSQLITE_DEBUG=1 \
		-DSQLITE_SYSTEM_MALLOC=1 -DSQLITE_OMIT_LOCALTIME=1 -DSQLITE_ENABLE_MATH_FUNCTIONS -DSQLITE_ENABLE_PERCENTILE \
		-DSQLITE_CDECL=__cdecl -DSQLITE_APICALL=__stdcall -DSQLITE_CALLBACK=__stdcall -DSQLITE_SYSAPI=WINAPI
SOURCES = \
	sqlite3.c
