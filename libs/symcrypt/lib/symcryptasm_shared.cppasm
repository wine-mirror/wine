#ifdef SYMCRYPT_PLATFORM_WINE
# define SYMCRYPT_GAS
# if defined __aarch64__ || defined __arm64ec__
#  define SYMCRYPT_CPU_ARM64 1
# elif defined __arm__
#  define SYMCRYPT_CPU_ARM 1
# elif defined __x86_64__
#  define SYMCRYPT_CPU_AMD64 1
# elif defined __i386__
#  define SYMCRYPT_CPU_X86 1
# endif
#endif

#include "C_asm_shared.inc"

// Platform-specific name mangling
// ARM64EC needs to use a modified function name as the code can co-exist with equivalent ARM64 code.
// macOS (Mach-O) needs to prefix all C symbols with an underscore.
#if defined __arm64ec__ && defined SYMCRYPT_GAS
    /* from compiler-rt assembly.h */
    #define GLUE2_(a, b) a##b
    #define GLUE2(a, b) GLUE2_(a, b)
    #define QUOTE(a) #a
    #define STR(a) QUOTE(a)
    #define HASH #
    #define PLATFORM_NAME_MANGLE(name) STR(GLUE2(HASH, name))
#elif defined _M_ARM64EC
    // ARM64EC name mangling for Windows
    #define ARM64EC_NAME_DECORATION_SYMBOL() #
    #define ARM64EC_NAME_DECORATE(FuncName) ARM64EC_NAME_DECORATION_SYMBOL() ## FuncName
    #define PLATFORM_NAME_MANGLE(FuncName) |ARM64EC_NAME_DECORATE(FuncName)|
#else
    #if defined(__APPLE__)
        // macOS/Mach-O requires underscore prefix for C symbols
        #define PLATFORM_NAME_MANGLE(FuncName) _ ## FuncName
    #else
        // No prefix for other platforms
        #define PLATFORM_NAME_MANGLE(FuncName) FuncName
    #endif
#endif

#if defined(SYMCRYPT_MASM)

    #if defined(SYMCRYPT_CPU_AMD64)
        include ksamd64.inc
    #elif defined(SYMCRYPT_CPU_ARM64)
        #include "ksarm64.h"
    #endif

    #define FILE_END()                      END
    #define ALIGN(__alignment)              align __alignment
    #define HEX(__constant)                 __constant##h
    #define TEXTAREA()                      TEXTAREA
    #define EXTERN(__label)                 EXTERN __label
    #define LABEL(__labelname)              __labelname
    #define GET_SYMBOL_ADDRESS(__symbol)    __symbol

#elif defined(SYMCRYPT_GAS)

    #if defined(SYMCRYPT_CPU_AMD64)
        .intel_syntax noprefix
    #endif

    #define FILE_END()
    #if defined(SYMCRYPT_CPU_AMD64)
        #define ALIGN(__alignment)          .balign __alignment
    #else
        #define ALIGN(__alignment)
    #endif
    #define HEX(__constant)                 0x##__constant
    #define TEXTAREA()
    #define EXTERN(__label)                 .extern __label
    #define LABEL(__labelname)              __labelname:

    #if defined(__APPLE__)
        #define GET_SYMBOL_ADDRESS(__symbol)    _ ## __symbol
    #else
        #define GET_SYMBOL_ADDRESS(__symbol)    __symbol+rip
    #endif

#else

    #error Unknown target assembly

#endif
