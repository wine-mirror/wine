#: programs/attrib/attrib.rc:50
msgid ""
"ATTRIB - Displays or changes file attributes.\n"
"\n"
"Syntax:\n"
"ATTRIB [+R | -R] [+A | -A ] [+S | -S] [+H | -H] [drive:][path][filename]\n"
"       [/S [/D]]\n"
"\n"
"Where:\n"
"\n"
"  +   Sets an attribute.\n"
"  -   Clears an attribute.\n"
"  R   Read-only file attribute.\n"
"  A   Archive file attribute.\n"
"  S   System file attribute.\n"
"  H   Hidden file attribute.\n"
"  [drive:][path][filename]\n"
"      Specifies a file or files for attrib to process.\n"
"  /S  Processes matching files in the current folder and all subfolders.\n"
"  /D  Processes folders as well.\n"
msgstr ""
"ATTRIB - а¶ңа·ңа¶ұа·” а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶« а¶ҙа·ҷа¶ұа·Ҡа¶ұа¶ұа·Җа·Ҹ а·„а·қ а·Җа·ҷа¶ұа·ға·Ҡ а¶ҡа¶»а¶ұа·Җа·Ҹ.\n"
"\n"
"а¶»а·“а¶ӯа·’:\n"
"ATTRIB [+R | -R] [+A | -A] [+S | -S] [+H | -H] [а¶°а·Ҹа·Җа¶ҡа¶ә:][а¶ҙа·ҷа¶ӯ][а¶ңа·ңа¶ұа·”а·Җ а¶ұа¶ё]\n"
"       [/S [/D]]\n"
"\n"
"а¶ҡа·ңа·„а·ҷа¶Ҝ:\n"
"\n"
"  +   а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ а¶Ҝа·Ҹа¶ұа·Җа·Ҹ.\n"
"  -   а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ а¶ёа¶ҡа¶ұа·Җа·Ҹ.\n"
"  R   а¶ҡа·’а¶әа·Җа·“а¶ёа·Ҡ а¶ҙа¶ёа¶«а·’ а¶ңа·ңа¶ұа·”а·Җа¶ҡ а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ.\n"
"  A   а·ға¶Ӯа¶»а¶ҡа·Ҡа·Ӯа·’а¶ӯа¶әа·ҡ а¶ңа·ңа¶ұа·”а·Җа¶ҡ а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ.\n"
"  S   а¶ҙа¶Ҝа·Ҡа¶°а¶ӯа·’а¶әа·ҡ а¶ңа·ңа¶ұа·”а·Җа¶ҡ а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ.\n"
"  H   а·„а¶Ӯа¶ңа¶ҙа·” а¶ңа·ңа¶ұа·”а·Җа¶ҡ а¶Ӣа¶ҙа¶Ҫа¶ҡа·ҠвҖҚа·Ӯа¶«а¶әа¶ҡа·Ҡ.\n"
"  [а¶°а·Ҹа·Җа¶ҡа¶ә:][а¶ҙа·ҷа¶ӯ][а¶ңа·ңа¶ұа·”а·Җ а¶ұа¶ё]\n"
"      а·ға¶ҡа·ға¶ұа·Ҡа¶ұ а¶•а¶ұа·ҡ а¶ңа·ңа¶ұа·”а·Җа¶ҡа·Ҡ а·„а·қ а¶ңа·ңа¶ұа·” а¶ұа·’а·Ға·Ҡа¶ а¶ә а¶ҡа¶»а¶ұа·Җа·Ҹ.\n"
"  /S  а¶ёа·ҡ а·Ҷа·қа¶Ҫа·Ҡа¶©а¶»а¶ә а·„а·Ҹ а¶әа¶§ а·Ҷа·қа¶Ҫа·Ҡа¶©а¶»а·Ҡ а·Җа¶Ҫ а¶Үа¶ӯа·”а¶Ҫа·ҡ а¶ңа·җа¶Ҫа¶ҙа·ҷа¶ұ а¶ңа·ңа¶ұа·” а·ға¶ҡа·ға¶ұа·Җа·Ҹ.\n"
"  /D  а·Ҷа·қа¶Ҫа·Ҡа¶©а¶»а·Ҡ а¶Ӣа¶ӯа·Ҡ а·ға¶ҡа·ға¶ұа·Җа·Ҹ.\n"

