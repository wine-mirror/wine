#: programs/cmd/cmd.rc:234
msgid "TIME sets or shows the current system time.\n"
msgstr ""

#: programs/cmd/cmd.rc:237
msgid "TITLE <string> sets the window title for the cmd window.\n"
msgstr "TITLE <а¶…а¶ұа·”а¶Ҫа¶ҡа·”а¶«а·” а·Җа·җа¶Ҫ> cmd а¶ҡа·Җа·”а·…а·”а·Җа¶§ а¶ҡа·Җа·”а·…а·”а·Җ а¶ұа¶ё а¶Ҝа·Ҹа¶ұа·Җа·Ҹ.\n"

#: programs/cmd/cmd.rc:241
#, fuzzy
msgid ""
"TYPE <filename> copies <filename> to the console device (or elsewhere if\n"
"redirected). No check is made that the file is readable text.\n"
msgstr ""
"TYPE <а¶ңа·ңа¶ұа·”а·Җ а¶ұа¶ё> copies <а¶ңа·ңа¶ұа·”а·Җ а¶ұа¶ё> to the console device (or elsewhere if\n"
"redirected). No check is made that the file is readable text.\n"

#: programs/cmd/cmd.rc:250
msgid ""
"VERIFY is used to set, clear or test the verify flag. Valid forms are:\n"
"\n"
"VERIFY ON\tSet the flag.\n"
"VERIFY OFF\tClear the flag.\n"
"VERIFY\t\tDisplays ON or OFF as appropriate.\n"
"\n"
"The verify flag has no function in Wine.\n"
msgstr ""

#: programs/cmd/cmd.rc:253
msgid "VER displays the version of cmd you are running.\n"
msgstr "VER а¶ҙа·Ҹа·Җа·’а¶ а·Ҡа¶ а·’ а¶ҡа¶»а¶ұ cmd а¶…а¶ұа·”а·Җа·Ҹа¶Ҝа¶ә а¶ҙа·ҷа¶ұа·Ҡа¶ұа¶ұа·Җа·Ҹ.\n"

#: programs/cmd/cmd.rc:256
msgid "VOL shows the volume label of a disk device.\n"
msgstr ""

#: programs/cmd/cmd.rc:260
msgid ""
"ENDLOCAL ends localization of environment changes in a batch file which\n"
"were introduced by a preceding SETLOCAL.\n"
msgstr ""

#: programs/cmd/cmd.rc:268
msgid ""
"SETLOCAL starts localization of environment changes in a batch file.\n"
"\n"
"Environment changes done after a SETLOCAL are local to the batch file, and\n"
"are preserved until the next ENDLOCAL is encountered (or at the end of the\n"
"file, whichever comes first), at which point the previous environment\n"
"settings are restored.\n"
msgstr ""

#: programs/cmd/cmd.rc:272
#, fuzzy
msgid ""
"PUSHD <directory> saves the current directory onto a stack, and then\n"
"changes the current directory to the supplied one.\n"
msgstr ""
"PUSHD <а¶©а·’а¶»а·ҷа¶ҡа·Ҡа¶§а¶»а·’а¶ә> saves the current directory onto a stack, and then\n"
"changes the current directory to the supplied one.\n"

#: programs/cmd/cmd.rc:275
msgid "POPD changes current directory to the last one saved with PUSHD.\n"
msgstr "POPD а·Җа¶ӯа·Ҡа¶ёа¶ұа·Ҡ а¶©а·’а¶»а·ҷа¶ҡа·Ҡа¶§а¶»а·’а¶ә а·Җа·ҷа¶ұа·ға·Ҡ а¶ҡа¶»а¶ұа·Җа·Ҹ PUSHD а¶…а¶ұа·Ҡа¶ӯа·’а¶ёа¶§ а·ға·”а¶»а·җа¶ҡа¶ҙа·” а¶‘а¶ҡа¶§.\n"

#: programs/cmd/cmd.rc:285
msgid ""
"ASSOC shows or modifies file extension associations.\n"
"\n"
"Syntax: ASSOC [.ext[=[fileType]]]\n"
"\n"
"ASSOC without parameters displays current file associations.\n"
"If used with only a file extension, displays the current association.\n"
"Specifying no file type after the equal sign removes the current\n"
"association, if any.\n"
msgstr ""

#: programs/cmd/cmd.rc:297
msgid ""
"FTYPE shows or modifies open commands associated with file types.\n"
"\n"
"Syntax: FTYPE [fileType[=[openCommand]]]\n"
"\n"
"Without parameters, shows the file types for which open command strings are\n"
"currently defined.\n"
"If used with only a file type, displays the associated open command string,\n"
"if any.\n"
"Specifying no open command after the equal sign removes the command string\n"
"associated to the specified file type.\n"
msgstr ""

#: programs/cmd/cmd.rc:300
msgid "MORE displays output of files or piped input in pages.\n"
msgstr ""

#: programs/cmd/cmd.rc:305
msgid ""
"CHOICE displays a text and waits, until the User presses an allowed Key\n"
"from a selectable list.\n"
"CHOICE is mainly used to build a menu selection in a batch file.\n"
msgstr ""

#: programs/cmd/cmd.rc:321
#, fuzzy
msgid ""
"Create a symbolic link.\n"
"\n"
"Syntax: MKLINK [options] link_name target\n"
"\n"
"Options:\n"
"/d             Create a directory symbolic link.\n"
"/h             Create a hard link.\n"
"/j             Create a directory junction.\n"
"link_name is the name of the new symbolic link.\n"
"target is the path that link_name points to.\n"
msgstr ""
"а·ға¶Ӯа¶ҡа·ҡа¶ӯа·Ҹа¶ӯа·Ҡа¶ёа¶ҡ а·ға¶¶а·җа¶іа·’а¶әа¶ҡа·Ҡ а·„а¶Ҝа¶ұа·Ҡа¶ұ.\n"
"\n"
"а¶»а·“а¶ӯа·’: MKLINK [а·Җа·’а¶ҡа¶Ҫа·Ҡа¶ҙ] а·ға¶¶а·җа¶іа·’а¶ә_а¶ұа¶ё а¶үа¶Ҫа¶ҡа·Ҡа¶ҡа¶ә\n"
"\n"
"а·Җа·’а¶ҡа¶Ҫа·Ҡа¶ҙ:\n"
"/d             а¶©а·’а¶»а·ҷа¶ҡа·Ҡа¶§а¶»а·’а¶әа¶ҡа¶ҡа¶§ а·ға¶Ӯа¶ҡа·ҡа¶ӯа·Ҹа¶ӯа·Ҡа¶ёа¶ҡ а·ға¶¶а·җа¶іа·’а¶әа¶ҡа·Ҡ а·„а¶Ҝа¶ұа·Ҡа¶ұ.\n"
"/h             а¶ӯа¶Ҝ а·ға¶¶а·җа¶іа·’а¶әа¶ҡа·Ҡ а·„а¶Ҝа¶ұа·Ҡа¶ұ.\n"
"/j             Create a directory junction.\n"
"link_name is the name of the new symbolic link.\n"
"target is the path that link_name points to.\n"

#: programs/cmd/cmd.rc:309
msgid ""
"EXIT terminates the current command session and returns to the operating\n"
"system or shell from which you invoked cmd.\n"
msgstr ""

